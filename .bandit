# Bandit configuration for sample-telco-sop-agent-for-strands
# These findings are intentional for this SOP execution agent

[bandit]
# Skip test files for certain checks
exclude_dirs = ['.git', '__pycache__', '.pytest_cache']

# Skipped tests with justification:
# B104: Binding to 0.0.0.0 is required for container deployment
# B108: Temp file usage in tests is acceptable (test isolation)
# B110: Try/except/pass is used for optional error handling
# B112: Try/except/continue is used in retry loops
# B404: subprocess module is required for SOP command execution
# B603: subprocess calls are intentional - this agent executes commands
# B607: Partial paths are used with known safe commands (kubectl, helm)
skips = ['B104', 'B110', 'B112']
